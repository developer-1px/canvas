{
  "compilerOptions": {
    "target": "es2023",
    "lib": ["ES2023", "DOM"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": false,
    "sourceMap": false,
    "outDir": "./dist/package",
    "rootDir": "./src",
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src/canvas/**/*.ts", "src/canvas/**/*.tsx"],
  "exclude": [
    "src/canvas/**/*.test.ts",
    "src/canvas/**/*.test.tsx",
    "src/canvas/architecture/**"
  ]
}
