{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023", "DOM"],
    "module": "esnext",
    "types": ["vite/client"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "paths": {
      "@interactive-os/canvas/editor": [
        "./src/canvas/editor-engine/index.ts"
      ],
      "@interactive-os/canvas/react-design": [
        "./src/canvas/react-design/index.ts"
      ],
      "@interactive-os/figjam-pack": [
        "./packages/figjam-pack/src/index.ts"
      ]
    },
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": [
    "src",
    "packages/canvas-devtools-affordance/src",
    "packages/canvas-pack-ai-labs/src",
    "packages/canvas-pack-devtools/src",
    "packages/dom-edit-affordance/src",
    "packages/slide-edit-affordance/src",
    "packages/figma-clone/src",
    "packages/figjam-pack/src"
  ]
}
