{
  "name": "canvas",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "types": "./src/canvas/index.ts",
  "exports": {
    ".": {
      "types": "./src/canvas/index.ts",
      "import": "./src/canvas/index.ts",
      "default": "./src/canvas/index.ts"
    },
    "./app": {
      "types": "./src/canvas/app/index.ts",
      "import": "./src/canvas/app/index.ts",
      "default": "./src/canvas/app/index.ts"
    },
    "./app/authoring": {
      "types": "./src/canvas/app/authoring/index.ts",
      "import": "./src/canvas/app/authoring/index.ts",
      "default": "./src/canvas/app/authoring/index.ts"
    },
    "./core": {
      "types": "./src/canvas/core/index.ts",
      "import": "./src/canvas/core/index.ts",
      "default": "./src/canvas/core/index.ts"
    },
    "./engine": {
      "types": "./src/canvas/engine/index.ts",
      "import": "./src/canvas/engine/index.ts",
      "default": "./src/canvas/engine/index.ts"
    },
    "./entities": {
      "types": "./src/canvas/entities/index.ts",
      "import": "./src/canvas/entities/index.ts",
      "default": "./src/canvas/entities/index.ts"
    },
    "./host": {
      "types": "./src/canvas/host/index.ts",
      "import": "./src/canvas/host/index.ts",
      "default": "./src/canvas/host/index.ts"
    },
    "./renderer": {
      "types": "./src/canvas/renderer/index.ts",
      "import": "./src/canvas/renderer/index.ts",
      "default": "./src/canvas/renderer/index.ts"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@interactive-os/object-surface": "link:../object-surface/packages/object-surface",
    "@interactive-os/preview-surface": "link:../preview-surface/packages/preview-surface",
    "@zod-crud/grouping": "link:../zod-crud/labs/extensions/grouping",
    "@zod-crud/layer-order": "link:../zod-crud/labs/extensions/layer-order",
    "@zod-crud/patch-preview": "link:../zod-crud/labs/extensions/patch-preview",
    "@zod-crud/search-replace": "link:../zod-crud/labs/extensions/search-replace",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zod": "^4.4.3",
    "zod-crud": "link:../zod-crud/packages/zod-crud"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^3.2.4"
  }
}
