{
  "name": "@interactive-os/canvas",
  "private": false,
  "version": "0.1.1",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "types": "./dist/package/canvas/index.d.ts",
  "files": [
    "dist/package",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org/"
  },
  "exports": {
    ".": {
      "types": "./dist/package/canvas/index.d.ts",
      "import": "./dist/package/canvas/index.js",
      "default": "./dist/package/canvas/index.js"
    },
    "./app": {
      "types": "./dist/package/canvas/app/index.d.ts",
      "import": "./dist/package/canvas/app/index.js",
      "default": "./dist/package/canvas/app/index.js"
    },
    "./app/authoring": {
      "types": "./dist/package/canvas/app/authoring/index.d.ts",
      "import": "./dist/package/canvas/app/authoring/index.js",
      "default": "./dist/package/canvas/app/authoring/index.js"
    },
    "./core": {
      "types": "./dist/package/canvas/core/index.d.ts",
      "import": "./dist/package/canvas/core/index.js",
      "default": "./dist/package/canvas/core/index.js"
    },
    "./foundation": {
      "types": "./dist/package/canvas/foundation/index.d.ts",
      "import": "./dist/package/canvas/foundation/index.js",
      "default": "./dist/package/canvas/foundation/index.js"
    },
    "./engine": {
      "types": "./dist/package/canvas/engine/index.d.ts",
      "import": "./dist/package/canvas/engine/index.js",
      "default": "./dist/package/canvas/engine/index.js"
    },
    "./entities": {
      "types": "./dist/package/canvas/entities/index.d.ts",
      "import": "./dist/package/canvas/entities/index.js",
      "default": "./dist/package/canvas/entities/index.js"
    },
    "./host": {
      "types": "./dist/package/canvas/host/index.d.ts",
      "import": "./dist/package/canvas/host/index.js",
      "default": "./dist/package/canvas/host/index.js"
    },
    "./renderer": {
      "types": "./dist/package/canvas/renderer/index.d.ts",
      "import": "./dist/package/canvas/renderer/index.js",
      "default": "./dist/package/canvas/renderer/index.js"
    },
    "./style.css": {
      "default": "./dist/package/canvas/app/shell/CanvasApp.css"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "npm run build:package && tsc -b && vite build",
    "build:package": "rm -rf dist/package && tsc -p tsconfig.package.json && node scripts/copy-package-assets.mjs && node scripts/resolve-package-imports.mjs",
    "lint": "eslint .",
    "pack:dry-run": "npm pack --dry-run",
    "prepack": "npm run build:package",
    "preview": "vite preview",
    "release:check": "npm run build:package && npm run smoke:package && npm run test -- src/canvas/host/document src/canvas/architecture && npm run build",
    "smoke:package": "node scripts/smoke-package.mjs",
    "test": "vitest run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@interactive-os/interaction": "^0.1.0",
    "@interactive-os/json-document": "^1.0.0",
    "@interactive-os/json-document-grouping": "^0.1.0",
    "@interactive-os/json-document-patch-preview": "^0.1.0",
    "@interactive-os/json-document-search-replace": "^0.1.0",
    "@interactive-os/object-surface": "^0.1.0",
    "@interactive-os/preview-surface": "^0.1.0",
    "lucide-react": "^1.16.0",
    "react-moveable": "^0.56.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^3.2.4"
  }
}
